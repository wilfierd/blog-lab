{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "uid": "aws-infra-v2",
  "title": "AWS Infrastructure — RDS · Redis · EC2",
  "tags": ["aws", "infra"],
  "timezone": "browser",
  "refresh": "60s",
  "time": { "from": "now-3h", "to": "now" },
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 2
      }
    ]
  },
  "panels": [

    { "id": 1, "title": "RDS PostgreSQL", "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },

    { "id": 2, "title": "Connections", "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "aws_rds_database_connections_average", "legendFormat": "connections" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "area", "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 80 }
          ]}
        }
      }
    },

    { "id": 3, "title": "CPU %", "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "aws_rds_cpuutilization_average", "legendFormat": "cpu" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizWidth": 75, "minVizHeight": 75,
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1, "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 80 }
          ]}
        }
      }
    },

    { "id": 4, "title": "Free Storage", "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "aws_rds_free_storage_space_average / 1073741824", "legendFormat": "free GB" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizWidth": 75, "minVizHeight": 75,
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes", "decimals": 1, "min": 0, "max": 20,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "green", "value": 10 }
          ]}
        }
      }
    },

    { "id": 5, "title": "Freeable Memory", "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "aws_rds_freeable_memory_average / 1073741824", "legendFormat": "GB free" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes", "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "green", "value": 1 }
          ]}
        }
      }
    },

    { "id": 6, "title": "Write Latency", "type": "stat",
      "gridPos": { "h": 2, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "aws_rds_write_latency_average * 1000", "legendFormat": "avg ms" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 50 }
          ]}
        }
      }
    },

    { "id": 7, "title": "Read Latency", "type": "stat",
      "gridPos": { "h": 2, "w": 4, "x": 16, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "aws_rds_read_latency_average * 1000", "legendFormat": "avg ms" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 50 }
          ]}
        }
      }
    },

    { "id": 8, "title": "RDS ALB Requests", "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "aws_applicationelb_request_count_sum", "legendFormat": "requests" },
        { "expr": "aws_applicationelb_httpcode_elb_5_xx_count_sum or vector(0)", "legendFormat": "5xx errors" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value", "graphMode": "none",
        "orientation": "vertical", "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx errors" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      }
    },

    { "id": 9, "title": "DB Connections over Time", "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "aws_rds_database_connections_average", "legendFormat": "connections" }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "spanNulls": true }
        }
      }
    },

    { "id": 10, "title": "RDS Latency over Time (ms)", "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "aws_rds_read_latency_average * 1000", "legendFormat": "read avg" },
        { "expr": "aws_rds_write_latency_average * 1000", "legendFormat": "write avg" },
        { "expr": "aws_rds_read_latency_maximum * 1000", "legendFormat": "read max" },
        { "expr": "aws_rds_write_latency_maximum * 1000", "legendFormat": "write max" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "max" },
            "properties": [{ "id": "custom.lineStyle", "value": { "dash": [8, 8], "fill": "dash" } }]
          }
        ]
      }
    },

    { "id": 20, "title": "ElastiCache Redis", "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "collapsed": false
    },

    { "id": 21, "title": "Cache Hit Rate", "type": "gauge",
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{
        "expr": "100 * aws_elasticache_cache_hits_sum / (aws_elasticache_cache_hits_sum + aws_elasticache_cache_misses_sum + 0.001)",
        "legendFormat": "hit rate"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizWidth": 75, "minVizHeight": 75,
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1, "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 80 },
            { "color": "green", "value": 95 }
          ]}
        }
      }
    },

    { "id": 22, "title": "Memory Used", "type": "gauge",
      "gridPos": { "h": 5, "w": 5, "x": 5, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{
        "expr": "aws_elasticache_bytes_used_for_cache_average / 1048576",
        "legendFormat": "MB used"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizWidth": 75, "minVizHeight": 75,
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes", "decimals": 0, "min": 0, "max": 512,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 350 },
            { "color": "red", "value": 460 }
          ]}
        }
      }
    },

    { "id": 23, "title": "Current Items", "type": "stat",
      "gridPos": { "h": 2, "w": 4, "x": 10, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "aws_elasticache_curr_items_average", "legendFormat": "items" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },

    { "id": 24, "title": "Connections", "type": "stat",
      "gridPos": { "h": 2, "w": 4, "x": 10, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "aws_elasticache_curr_connections_average", "legendFormat": "connections" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 200 }
          ]}
        }
      }
    },

    { "id": 25, "title": "Evictions", "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 14, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "aws_elasticache_evictions_sum", "legendFormat": "evictions" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 100 }
          ]}
        }
      }
    },

    { "id": 26, "title": "Hits vs Misses (per min)", "type": "timeseries",
      "gridPos": { "h": 5, "w": 10, "x": 18, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "aws_elasticache_cache_hits_sum", "legendFormat": "hits" },
        { "expr": "aws_elasticache_cache_misses_sum", "legendFormat": "misses" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "hits" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          { "matcher": { "id": "byName", "options": "misses" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      }
    },

    { "id": 30, "title": "EC2 & Auto Scaling", "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },

    { "id": 31, "title": "CPU Average", "type": "gauge",
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "avg(aws_ec2_cpuutilization_average)", "legendFormat": "cpu avg %" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizWidth": 75, "minVizHeight": 75
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1, "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 80 }
          ]}
        }
      }
    },

    { "id": 32, "title": "CPU Max", "type": "stat",
      "gridPos": { "h": 2, "w": 4, "x": 5, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "max(aws_ec2_cpuutilization_maximum)", "legendFormat": "cpu max %" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]}
        }
      }
    },

    { "id": 33, "title": "Instances In Service", "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 5, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "aws_autoscaling_group_in_service_instances_average", "legendFormat": "in service" },
        { "expr": "aws_autoscaling_group_desired_capacity_average", "legendFormat": "desired" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value", "graphMode": "none",
        "orientation": "vertical", "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },

    { "id": 34, "title": "ALB Response Time (ms)", "type": "timeseries",
      "gridPos": { "h": 5, "w": 9, "x": 9, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "aws_applicationelb_target_response_time_average * 1000", "legendFormat": "avg ms" },
        { "expr": "aws_applicationelb_target_response_time_maximum * 1000", "legendFormat": "max ms" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "max ms" },
            "properties": [{ "id": "custom.lineStyle", "value": { "dash": [8, 8], "fill": "dash" } }]
          }
        ]
      }
    },

    { "id": 35, "title": "ALB Request Count", "type": "timeseries",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "aws_applicationelb_request_count_sum", "legendFormat": "requests" },
        { "expr": "aws_applicationelb_httpcode_target_2_xx_count_sum", "legendFormat": "2xx" },
        { "expr": "aws_applicationelb_httpcode_elb_5_xx_count_sum or vector(0)", "legendFormat": "5xx" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          { "matcher": { "id": "byName", "options": "5xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },

    { "id": 40, "title": "EC2 CPU over Time", "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "aws_ec2_cpuutilization_average", "legendFormat": "avg {{auto_scaling_group_name}}" },
        { "expr": "aws_ec2_cpuutilization_maximum", "legendFormat": "max {{auto_scaling_group_name}}" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 80 }
          ]}
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "^max" },
            "properties": [{ "id": "custom.lineStyle", "value": { "dash": [8, 8], "fill": "dash" } }]
          }
        ]
      }
    },

    { "id": 41, "title": "ASG Instance Count", "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "aws_autoscaling_group_in_service_instances_average", "legendFormat": "in service" },
        { "expr": "aws_autoscaling_group_desired_capacity_average", "legendFormat": "desired" },
        { "expr": "aws_autoscaling_group_min_size_average", "legendFormat": "min" },
        { "expr": "aws_autoscaling_group_max_size_average", "legendFormat": "max" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "in service" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          { "matcher": { "id": "byName", "options": "desired" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          { "matcher": { "id": "byName", "options": "min" },
            "properties": [{ "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
                           { "id": "color", "value": { "fixedColor": "gray", "mode": "fixed" } }]
          },
          { "matcher": { "id": "byName", "options": "max" },
            "properties": [{ "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
                           { "id": "color", "value": { "fixedColor": "gray", "mode": "fixed" } }]
          }
        ]
      }
    }

  ]
}
