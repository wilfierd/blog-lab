{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "uid": "aws-ec2-alb",
  "title": "AWS EC2 & ALB",
  "tags": [
    "aws",
    "ec2",
    "alb"
  ],
  "timezone": "browser",
  "refresh": "60s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "id": 30,
      "title": "EC2 & Auto Scaling",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 31,
      "title": "CPU Average",
      "type": "gauge",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "avg(aws_ec2_cpuutilization_average)",
          "legendFormat": "cpu avg %"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "minVizWidth": 75,
        "minVizHeight": 75
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        }
      }
    },
    {
      "id": 32,
      "title": "CPU Max",
      "type": "stat",
      "gridPos": {
        "h": 2,
        "w": 4,
        "x": 5,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "max(aws_ec2_cpuutilization_maximum)",
          "legendFormat": "cpu max %"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "id": 33,
      "title": "Instances In Service",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 5,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "aws_autoscaling_group_in_service_instances_average",
          "legendFormat": "in service"
        },
        {
          "expr": "aws_autoscaling_group_desired_capacity_average",
          "legendFormat": "desired"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "vertical",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "id": 34,
      "title": "ALB Response Time (ms)",
      "type": "timeseries",
      "gridPos": {
        "h": 5,
        "w": 9,
        "x": 9,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "aws_applicationelb_target_response_time_average * 1000",
          "legendFormat": "avg ms"
        },
        {
          "expr": "aws_applicationelb_target_response_time_maximum * 1000",
          "legendFormat": "max ms"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "max ms"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    8,
                    8
                  ],
                  "fill": "dash"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 35,
      "title": "ALB Request Count",
      "type": "timeseries",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "aws_applicationelb_request_count_sum",
          "legendFormat": "requests"
        },
        {
          "expr": "aws_applicationelb_httpcode_target_2_xx_count_sum",
          "legendFormat": "2xx"
        },
        {
          "expr": "aws_applicationelb_httpcode_elb_5_xx_count_sum or vector(0)",
          "legendFormat": "5xx"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "2xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "5xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 40,
      "title": "EC2 CPU over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "aws_ec2_cpuutilization_average",
          "legendFormat": "avg {{auto_scaling_group_name}}"
        },
        {
          "expr": "aws_ec2_cpuutilization_maximum",
          "legendFormat": "max {{auto_scaling_group_name}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max",
            "mean"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^max"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    8,
                    8
                  ],
                  "fill": "dash"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 41,
      "title": "ASG Instance Count",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "aws_autoscaling_group_in_service_instances_average",
          "legendFormat": "in service"
        },
        {
          "expr": "aws_autoscaling_group_desired_capacity_average",
          "legendFormat": "desired"
        },
        {
          "expr": "aws_autoscaling_group_min_size_average",
          "legendFormat": "min"
        },
        {
          "expr": "aws_autoscaling_group_max_size_average",
          "legendFormat": "max"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "in service"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "desired"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "min"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    4,
                    4
                  ],
                  "fill": "dash"
                }
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "gray",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "max"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    4,
                    4
                  ],
                  "fill": "dash"
                }
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "gray",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 50,
      "title": "RAM Used %",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes{job='ec2-node'} - node_memory_MemAvailable_bytes{job='ec2-node'}) / node_memory_MemTotal_bytes{job='ec2-node'} * 100",
          "legendFormat": "RAM %"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      }
    },
    {
      "id": 51,
      "title": "RAM Free",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes{job='ec2-node'}",
          "legendFormat": "free"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 268435456
              },
              {
                "color": "green",
                "value": 536870912
              }
            ]
          }
        }
      }
    },
    {
      "id": 52,
      "title": "Disk Used % (/)",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "(node_filesystem_size_bytes{job='ec2-node',mountpoint='/',fstype!='tmpfs'} - node_filesystem_free_bytes{job='ec2-node',mountpoint='/',fstype!='tmpfs'}) / node_filesystem_size_bytes{job='ec2-node',mountpoint='/',fstype!='tmpfs'} * 100",
          "legendFormat": "Disk %"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      }
    },
    {
      "id": 53,
      "title": "Disk Free (/)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{job='ec2-node',mountpoint='/',fstype!='tmpfs'}",
          "legendFormat": "free"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2147483648
              },
              {
                "color": "green",
                "value": 5368709120
              }
            ]
          }
        }
      }
    },
    {
      "id": 54,
      "title": "RAM over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{job='ec2-node'}",
          "legendFormat": "Total"
        },
        {
          "expr": "node_memory_MemTotal_bytes{job='ec2-node'} - node_memory_MemAvailable_bytes{job='ec2-node'}",
          "legendFormat": "Used"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{job='ec2-node'}",
          "legendFormat": "Available"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 55,
      "title": "Disk Usage over Time (/)",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "node_filesystem_size_bytes{job='ec2-node',mountpoint='/',fstype!='tmpfs'}",
          "legendFormat": "Total"
        },
        {
          "expr": "node_filesystem_size_bytes{job='ec2-node',mountpoint='/',fstype!='tmpfs'} - node_filesystem_free_bytes{job='ec2-node',mountpoint='/',fstype!='tmpfs'}",
          "legendFormat": "Used"
        },
        {
          "expr": "node_filesystem_avail_bytes{job='ec2-node',mountpoint='/',fstype!='tmpfs'}",
          "legendFormat": "Available"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 10
          }
        }
      }
    }
  ]
}